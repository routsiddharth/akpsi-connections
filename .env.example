# Copy to .env for local dev. On Railway these are injected by the Postgres/Neo4j plugins.
#
# Postgres: Railway's Postgres plugin exposes DATABASE_URL automatically.
# Locally, docker-compose.yml serves this exact URL.
# Host port 5433 (see docker-compose.yml) avoids clashing with a native Postgres on 5432.
DATABASE_URL=postgresql://akpsi:akpsi@127.0.0.1:5433/akpsi

# Neo4j: Railway's Neo4j template exposes these. docker-compose serves them locally.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=akpsi_neo4j

# Fuzzy-match thresholds (rapidfuzz token_sort_ratio, 0-100)
FUZZY_AUTO_MERGE=92   # >= this -> auto-merge to existing canonical firm
FUZZY_REVIEW_MIN=80   # [REVIEW_MIN, AUTO_MERGE) -> goes to manual review queue
